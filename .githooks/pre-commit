#!/usr/bin/env bash
set -e

# Ensure Go tools are in PATH
export PATH="${GOPATH:-$HOME/go}/bin:$PATH"

echo "→ Running gofumpt..."
gofumpt -l -d . | head -20
if [ -n "$(gofumpt -l .)" ]; then
    echo "✗ gofumpt: files need formatting. Run: gofumpt -w ."
    exit 1
fi

echo "→ Running goimports..."
if command -v goimports &>/dev/null; then
    BAD=$(goimports -l -local github.com/yashiels/twitter-cli .)
    if [ -n "$BAD" ]; then
        echo "✗ goimports: imports need fixing in: $BAD"
        exit 1
    fi
fi

echo "→ Running go vet..."
go vet ./...

echo "→ Running golangci-lint..."
if command -v golangci-lint &>/dev/null; then
    golangci-lint run --timeout=5m
else
    echo "⚠ golangci-lint not found, skipping (install: go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@latest)"
fi

echo "✓ All checks passed"
